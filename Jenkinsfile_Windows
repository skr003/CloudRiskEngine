pipeline {
    // Optionally specify a Windows node if you have a mixed environment: agent { label 'windows' }
    agent any

    environment {
        // Credentials binding for Neo4j Password
        // NEO4J_PASSWORD = credentials('neo4j-db-password') 
        
        // Azure Credentials 
        // Ensure you have these bound in your Jenkins credentials if not using a global SP
        AZURE_CLIENT_ID = credentials('AZURE_CLIENT_ID')
        AZURE_CLIENT_SECRET = credentials('AZURE_CLIENT_SECRET')
        AZURE_TENANT_ID = credentials('AZURE_TENANT_ID')
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Setup Dependencies') {
            steps {
                // Windows typically uses 'pip' and 'python' rather than 'pip3'/'python3'
                bat 'C:/Users/admin/AppData/Local/Programs/Python/Python312/Scripts/pip.exe install -r scripts/requirements.txt'
            }
        }

        stage('Cloud Data Collector') {
            steps {
                script {
                    echo "Logging into Azure..."
                    // Use %VAR% syntax for environment variables in Windows batch scripts
                    bat 'az login --service-principal -u "%AZURE_CLIENT_ID%" -p "%AZURE_CLIENT_SECRET%" --tenant "%AZURE_TENANT_ID%"'
                    
                    echo "Running Collector Module..."
                    // Calls bash explicitly. Ensure Git Bash is in your Windows PATH.
                    bat '"C:/Program Files/Git/bin/sh.exe" scripts/collect_iam_data.sh'
                }
            }
        }

        stage('Privilege Analysis (Graph Build)') {
            steps {
                script {
                    echo "Building Cypher Import File..."
                    // Generate the .cypher file
                    bat '"C:/Program Files/Git/bin/sh.exe" scripts/build_graph.sh'
            
                    echo "Uploading to Neo4j via Python Driver..."
                    // Execute the import using the driver installed in your Python environment
                    bat '"C:/Users/admin/AppData/Local/Programs/Python/Python312/python.exe" scripts/load_to_neo4j.py'
            
                    // Cleanup
                    bat 'del import.cypher'
                  }
             }
        }

        stage('Threat Intel Mapping') {
            steps {
                script {
                    echo "Mapping MITRE TTPs..."
                    bat '"C:/Users/admin/AppData/Local/Programs/Python/Python312/python.exe" scripts/map_mitre.py'
                    
                    echo "Importing TTPs to Graph..."
                    bat '"C:/Users/admin/AppData/Local/Programs/Python/Python312/python.exe" scripts/import_mitre.sh'
                }
            }
        }

        stage('Remediation & Reporting') {
            steps {
                script {
                    echo "Generating Remediation Plans..."
                    bat '"C:/Users/admin/AppData/Local/Programs/Python/Python312/python.exe" scripts/remediation.py'
                }
            }
        }
        
        stage('Deploy Dashboard') {
            steps {
                echo "Dashboard is ready. Open a terminal and run: streamlit run dashboard/app.py"
            }
        }
    }

    post {
        always {
            // Uses backslashes for Windows artifact paths
            archiveArtifacts artifacts: 'output\\*.*', allowEmptyArchive: true
            sleep(time: 2, unit: 'SECONDS') 
            cleanWs(disableDeferredWipeout: true, deleteDirs: true)
        }
    }
}
