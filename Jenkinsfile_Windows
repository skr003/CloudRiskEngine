pipeline {
    agent any

    environment {
        // Credentials binding for Neo4j Password
        // NEO4J_PASSWORD = credentials('neo4j-db-password') 
        
        // Azure Credentials 
        // Ensure you have these bound in your Jenkins credentials if not using a global SP
        AZURE_CLIENT_ID = credentials('AZURE_CLIENT_ID')
        AZURE_CLIENT_SECRET = credentials('AZURE_CLIENT_SECRET')
        AZURE_TENANT_ID = credentials('AZURE_TENANT_ID')
    }

    stages {
        stage('Setup Dependencies') {
            steps {
                bat 'C:/Users/admin/AppData/Local/Programs/Python/Python312/Scripts/pip.exe install -r scripts/requirements.txt'
            }
        }

        stage('1. Azure Cloud') {
            steps {
                script {
                    echo "[*] Connecting to Azure Cloud Environment..."
                    // Placeholder: Azure CLI login or Service Principal authentication
                    bat 'az login --service-principal -u "%AZURE_CLIENT_ID%" -p "%AZURE_CLIENT_SECRET%" --tenant "%AZURE_TENANT_ID%"'
                }
            }
        }

        stage('2. Cloud Data Collector Module') {
            steps {
                script {
                    echo "[*] Pulling IAM/Role Data and Activity Logs via Graph API..."
                    // Placeholder: Your script that fetches data and creates the output JSONs
                    bat '"C:/Program Files/Git/bin/sh.exe" scripts/collect_iam_data.sh'
                }
            }
        }

        stage('3. Privilege Analysis & Risk Engine') {
            steps {
                script {
                    echo "[*] Constructing Permission Graph in Neo4j..."
                    bat '"C:/Program Files/Git/bin/sh.exe" scripts/build_graph.sh'
                    bat '"C:/Users/admin/AppData/Local/Programs/Python/Python312/python.exe" scripts/load_to_neo4j.py'            
                    
                    // Cleanup intermediate file
                    bat 'del import.cypher'
                }
            }
        }

        stage('4. Remediation Engine') {
            steps {
                script {
                    echo "[*] Generating Least Privilege Suggestions & Policy-as-Code..."
                    // Placeholder: Script to generate Terraform fixes or trigger Jira tickets
                    // bat 'python scripts/generate_tf_fixes.py'
                }
            }
        }

        stage('5. Threat Intelligence / MITRE Mapping Engine') {
            steps {
                script {
                    echo "[*] Mapping activities to known TTPs in the Graph..."
                    bat '"C:/Program Files/Git/bin/sh.exe" scripts/import_mitre.sh'
                    bat '"C:/Users/admin/AppData/Local/Programs/Python/Python312/python.exe" scripts/load_mitre.py'
                    
                    // Cleanup intermediate file
                    bat 'del mitre.cypher'
                }
            }
        }

        stage('6. Risk Dashboard & Reporting') {
            steps {
                script {
                    echo "[*] Generating Heatmaps and updating Web UI..."
                    // Placeholder: Deploying/Updating your Streamlit or Grafana dashboard
                    // bat 'streamlit run dashboard/app.py' 
                }
            }
        }
    }

    post {
        always {
            script {
                echo "[*] Pipeline finished. Preparing to clean workspace..."
                sleep(time: 2, unit: 'SECONDS') 
            }
            cleanWs(disableDeferredWipeout: true, deleteDirs: true)
            echo "[+] Workspace cleaned successfully."
        }
        success {
            echo "✅ Build Successful! End-to-End Cloud Risk Engine execution complete."
        }
        failure {
            echo "❌ Build Failed. Check the logs for errors."
        }
    }
}
